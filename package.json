{
  "name": "skill-bridge",
  "version": "1.0.0",
  "description": "",
  "main": "api/index.js",
  "type": "module",
  "scripts": {
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "dev": "nodemon --watch src --watch .env --ext ts,json --exec tsx src/index.ts",
    "dev:poll": "nodemon --watch src --watch .env --ext ts,json --legacy-watch --exec tsx src/index.ts",
    "build": "prisma generate && tsup src/index.ts --format esm --platform node --target node20 --outDir api --external pg-native",
    "start": "node api/index.js",
    "start:prod": "prisma migrate deploy && node api/index.js",
    "seed:admin": "tsx src/scripts/seedAdmin.ts",
    "update-stats": "tsx src/scripts/updateTutorStats.ts",
    "seed": "tsx prisma/seed.ts",
    "sync:embeddings": "tsx src/scripts/syncEmbeddings.ts",
    "postinstall": "prisma generate",
    "docker:build": "docker build -t skillbridge-server .",
    "docker:run": "docker run -p 10000:10000 skillbridge-server"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/hpp": "^0.2.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^25.2.1",
    "@types/nodemailer": "^7.0.4",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "nodemon": "^3.1.9",
    "prettier": "^3.2.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.4.17",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "kafkajs": "^2.2.4",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^7.0.12",
    "pg": "^8.17.2",
    "prisma": "^7.3.0",
    "prom-client": "^15.1.3",
    "redis": "^5.11.0",
    "stripe": "^22.0.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "zod": "^3.24.1"
  }
}
